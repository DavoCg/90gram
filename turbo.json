{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "DATABASE_URL",
    "API_PORT",
    "API_BASE_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "ADMIN_BASE_URL",
    "ADMIN_PORT",
    "PORT",
    "APP_SCHEME",
    "RESEND_API_KEY",
    "RESEND_FROM",
    "EXPO_PUBLIC_API_BASE_URL",
    "DISCOGS_TOKEN",
    "DISCOGS_FIXTURE",
    "NODE_ENV",
    "JOBS_PORT",
    "JOB_TIMEZONE",
    "TRACK_DURATIONS_CRON",
    "JOB_CONCURRENCY",
    "JOB_BATCH_SIZE",
    "JOB_REQUEST_TIMEOUT_MS",
    "JOB_MAX_TRACKS",
    "SCRAPYD_URL",
    "SCRAPYD_PROJECT",
    "SCRAPE_DISCOGS_CRON",
    "SCRAPE_COLDCUTSHOTWAX_CRON",
    "SCRAPE_DEEJAY_CRON",
    "SCRAPE_DANCINGVINYL_CRON",
    "SCRAPE_POLL_INTERVAL_MS",
    "SCRAPE_MAX_WAIT_MS"
  ],
  "globalDependencies": [".env", ".env.example"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false,
      "outputs": ["src/generated/**"]
    },
    "gen:openapi": {
      "dependsOn": ["@getvinyls/db#db:generate"],
      "outputs": ["openapi.json"]
    },
    "gen:api-types": {
      "dependsOn": ["@getvinyls/api#gen:openapi"],
      "outputs": ["src/schema.d.ts"]
    },
    "build": {
      "dependsOn": ["^build", "@getvinyls/db#db:generate", "@getvinyls/api-client#gen:api-types"],
      "outputs": ["dist/**", ".expo/**"]
    },
    "typecheck": {
      "dependsOn": ["@getvinyls/db#db:generate", "@getvinyls/api-client#gen:api-types"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "scrape": {
      "cache": false,
      "persistent": false
    }
  }
}
