{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalEnv": [
    "DATABASE_URL",
    "API_PORT",
    "API_BASE_URL",
    "EXPO_PUBLIC_API_BASE_URL",
    "DISCOGS_TOKEN",
    "DISCOGS_FIXTURE",
    "NODE_ENV"
  ],
  "globalDependencies": [".env", ".env.example"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": false,
      "outputs": ["src/generated/**"]
    },
    "gen:openapi": {
      "dependsOn": ["@getvinyls/db#db:generate"],
      "outputs": ["openapi.json"]
    },
    "gen:api-types": {
      "dependsOn": ["@getvinyls/api#gen:openapi"],
      "outputs": ["src/schema.d.ts"]
    },
    "build": {
      "dependsOn": ["^build", "@getvinyls/db#db:generate", "@getvinyls/api-client#gen:api-types"],
      "outputs": ["dist/**", ".expo/**"]
    },
    "typecheck": {
      "dependsOn": ["@getvinyls/db#db:generate", "@getvinyls/api-client#gen:api-types"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "scrape": {
      "cache": false,
      "persistent": false
    }
  }
}
