{
  "name": "getvinyls",
  "private": true,
  "version": "0.1.0",
  "description": "getvinyls monorepo: vinyl record discovery app (mobile + API + scraper).",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "gen:api-types": "turbo run gen:api-types",
    "scrape": "turbo run scrape",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md}\"",
    "db:migrate": "pnpm --filter @getvinyls/db migrate",
    "db:seed": "pnpm --filter @getvinyls/db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.40.0",
    "eslint": "^9.40.0",
    "prettier": "^3.6.2",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0"
  }
}
