{
  "name": "getvinyls",
  "private": true,
  "version": "0.1.0",
  "description": "getvinyls monorepo: vinyl record discovery app (mobile + API + scraper).",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "gen:api-types": "turbo run gen:api-types",
    "scrape": "turbo run scrape",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,cjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,cjs,json,md}\"",
    "db:migrate": "pnpm --filter @getvinyls/db migrate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "turbo": "^2.9.16",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.60.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "sharp"
    ]
  }
}
