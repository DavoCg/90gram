# getvinyls environment.
# Copy to .env and fill in. Validated with Zod at boot (apps/api), fail-fast on missing vars.

# Single Postgres URL shared by Prisma (packages/db) and the scraper (apps/scraper).
# Prisma OWNS the schema and migrations; the scraper only writes rows.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/getvinyls?schema=public"

# API server (apps/api)
API_PORT="8787"
API_BASE_URL="http://127.0.0.1:8787"

# Authentication (better-auth, apps/api). BETTER_AUTH_SECRET signs sessions/tokens and is REQUIRED;
# generate one with `openssl rand -base64 32`. BETTER_AUTH_URL is where the auth handler is reachable
# (/api/auth/*). APP_SCHEME is the mobile deep-link scheme (matches apps/mobile/app.json), added to
# better-auth trustedOrigins.
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://127.0.0.1:8787"
APP_SCHEME="getvinyls"

# Email delivery for sign-in one-time codes (Resend). Leave RESEND_API_KEY empty in development:
# codes are logged to the API console instead of being emailed. Set it in production to send mail.
RESEND_API_KEY=""
RESEND_FROM="getvinyls <onboarding@resend.dev>"

# Currency conversion (apps/api). Prices are stored in their original currency and converted to the
# user's chosen display currency using EUR-based exchange rates from Frankfurter (frankfurter.dev),
# cached in memory. FRANKFURTER_BASE_URL points at the API (override only for a mirror or tests);
# EXCHANGE_RATES_TTL_MS bounds how stale a cached rate table may get (default 6h). Both are optional.
FRANKFURTER_BASE_URL="https://api.frankfurter.dev/v1"
EXCHANGE_RATES_TTL_MS="21600000"

# Mobile app (apps/mobile). EXPO_PUBLIC_ vars are inlined into the JS bundle.
# Use your machine's LAN IP (not 127.0.0.1) so a physical device can reach the API.
EXPO_PUBLIC_API_BASE_URL="http://127.0.0.1:8787"

# Scraper (apps/scraper). Discogs official API token: https://www.discogs.com/settings/developers
# Leave empty to run the spider in offline fixture mode (see apps/scraper/README.md).
DISCOGS_TOKEN=""
# Optional path to a local JSON fixture; when set, the spider reads it instead of the network.
DISCOGS_FIXTURE="fixtures/discogs_sample.json"

# Jobs service (apps/jobs). Background jobs with direct DB access (shares DATABASE_URL above). All
# optional with sane defaults; tune only if needed. JOB_CONCURRENCY caps simultaneous preview
# downloads (politeness), JOB_BATCH_SIZE is the DB page size, JOB_REQUEST_TIMEOUT_MS aborts a slow
# download, JOB_MAX_TRACKS optionally caps how many tracks a single run processes (e.g. a smoke run).
JOB_CONCURRENCY="8"
JOB_BATCH_SIZE="100"
JOB_REQUEST_TIMEOUT_MS="15000"
JOB_MAX_TRACKS=""

# ColdCuts // HotWax spider (apps/scraper, crawl "coldcutshotwax"). No credentials: the Shopify
# catalog JSON is public. Optional path to a local JSON fixture (a list of raw Shopify product
# objects); when set, the spider reads it instead of crawling the live site. See the README.
CCHW_FIXTURE=""
