# getvinyls environment.
# Copy to .env and fill in. Validated with Zod at boot (apps/api), fail-fast on missing vars.

# Single Postgres URL shared by Prisma (packages/db) and the scraper (apps/scraper).
# Prisma OWNS the schema and migrations; the scraper only writes rows.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/getvinyls?schema=public"

# API server (apps/api)
API_PORT="8787"
API_BASE_URL="http://127.0.0.1:8787"

# Authentication (better-auth, apps/api). BETTER_AUTH_SECRET signs sessions/tokens and is REQUIRED;
# generate one with `openssl rand -base64 32`. BETTER_AUTH_URL is where the auth handler is reachable
# (/api/auth/*). APP_SCHEME is the mobile deep-link scheme (matches apps/mobile/app.json), added to
# better-auth trustedOrigins.
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://127.0.0.1:8787"
APP_SCHEME="getvinyls"

# Admin app (apps/admin, TanStack Start). Shares DATABASE_URL, BETTER_AUTH_SECRET and the RESEND_*
# vars above. ADMIN_BASE_URL is where the admin's own better-auth handler is reachable (/api/auth/*);
# ADMIN_PORT is the local dev/server port. Access requires a user with role == "admin" (promote with
# `pnpm --filter @getvinyls/admin promote <email>`).
ADMIN_BASE_URL="http://localhost:3000"
ADMIN_PORT="3000"

# Email delivery for sign-in one-time codes (Resend). Leave RESEND_API_KEY empty in development:
# codes are logged to the API console instead of being emailed. Set it in production to send mail.
RESEND_API_KEY=""
RESEND_FROM="getvinyls <onboarding@resend.dev>"

# Currency conversion (apps/api). Prices are stored in their original currency and converted to the
# user's chosen display currency using EUR-based exchange rates from Frankfurter (frankfurter.dev),
# cached in memory. FRANKFURTER_BASE_URL points at the API (override only for a mirror or tests);
# EXCHANGE_RATES_TTL_MS bounds how stale a cached rate table may get (default 6h). Both are optional.
FRANKFURTER_BASE_URL="https://api.frankfurter.dev/v1"
EXCHANGE_RATES_TTL_MS="21600000"

# Full-text search (Meilisearch). The search index is a DERIVED view of the canonical vinyls: the
# jobs service (apps/jobs reindex-vinyls) rebuilds it from Postgres on its cron and once at launch;
# the API (apps/api) only READS it for GET /vinyls/search and hydrates results from the DB. Run a
# local server with `docker run -p 7700:7700 getmeili/meilisearch` (optionally with a master key).
# MEILI_HOST is the server base URL; leave it empty to disable search (the route answers 503 and the
# reindex job no-ops, so the app still runs without a search server in development).
MEILI_HOST="http://127.0.0.1:7700"
# Admin (write) key used by the jobs service to configure the index and push documents. Match the
# server's master key. Leave empty when running Meilisearch without a master key (dev only).
MEILI_MASTER_KEY=""
# Search-only (read) key used by the API. Generate a scoped search key in production; in dev with no
# master key, leave it empty. Never ship the master key to the read side.
MEILI_SEARCH_KEY=""
# Schedule (5-field cron, evaluated in JOB_TIMEZONE) for rebuilding the search index. Default 6h.
REINDEX_VINYLS_CRON="0 */6 * * *"

# Mobile app (apps/mobile). EXPO_PUBLIC_ vars are inlined into the JS bundle.
# Use your machine's LAN IP (not 127.0.0.1) so a physical device can reach the API.
EXPO_PUBLIC_API_BASE_URL="http://127.0.0.1:8787"

# Scraper (apps/scraper). Discogs official API token: https://www.discogs.com/settings/developers
# Leave empty to run the spider in offline fixture mode (see apps/scraper/README.md).
DISCOGS_TOKEN=""
# Optional path to a local JSON fixture; when set, the spider reads it instead of the network.
DISCOGS_FIXTURE="fixtures/discogs_sample.json"

# Jobs service (apps/jobs). Always-on worker: a scheduler daemon fires each job on its in-process
# cron (shares DATABASE_URL above). All optional with sane defaults; tune only if needed.
# JOBS_PORT is the daemon's /health port; JOB_TIMEZONE is the IANA tz the crons run in;
# TRACK_DURATIONS_CRON is the schedule for the track-durations job (5-field cron, default daily 03:00).
# JOB_CONCURRENCY caps simultaneous preview downloads (politeness), JOB_BATCH_SIZE is the DB page
# size, JOB_REQUEST_TIMEOUT_MS aborts a slow download, JOB_MAX_TRACKS optionally caps how many tracks
# a single run processes (e.g. a smoke run).
JOBS_PORT="8080"
JOB_TIMEZONE="UTC"
TRACK_DURATIONS_CRON="0 3 * * *"
JOB_CONCURRENCY="8"
JOB_BATCH_SIZE="100"
JOB_REQUEST_TIMEOUT_MS="15000"
JOB_MAX_TRACKS=""

# ColdCuts // HotWax spider (apps/scraper, crawl "coldcutshotwax"). No credentials: the Shopify
# catalog JSON is public. Optional path to a local JSON fixture (a list of raw Shopify product
# objects); when set, the spider reads it instead of crawling the live site. See the README.
CCHW_FIXTURE=""

# Scrapyd scheduling (apps/jobs -> apps/scraper). In the cloud the spiders run on a Scrapyd daemon
# (the getvinyls-scraper Fly app); the jobs daemon drives it, POSTing each spider's run to
# schedule.json on its cron. SCRAPYD_URL is the daemon's base URL (default points at the private Fly
# address); SCRAPYD_PROJECT matches the Scrapy project name. The SCRAPE_*_CRON vars are staggered
# 5-field schedules (in JOB_TIMEZONE) so the shops are crawled one at a time. SCRAPE_POLL_INTERVAL_MS
# is how often a job polls Scrapyd for completion; SCRAPE_MAX_WAIT_MS bounds how long it waits before
# giving up on a stuck crawl. All optional with sane defaults; tune only if needed.
SCRAPYD_URL="http://getvinyls-scraper.internal:6800"
SCRAPYD_PROJECT="getvinyls_scraper"
SCRAPE_DISCOGS_CRON="0 2 * * *"
SCRAPE_COLDCUTSHOTWAX_CRON="0 4 * * *"
SCRAPE_DEEJAY_CRON="0 5 * * *"
SCRAPE_DANCINGVINYL_CRON="0 6 * * *"
SCRAPE_POLL_INTERVAL_MS="15000"
SCRAPE_MAX_WAIT_MS="1800000"
