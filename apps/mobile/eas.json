{
  "cli": {
    "version": ">= 20.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "node": "22.20.0",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://127.0.0.1:8787"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "node": "22.20.0"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "node": "22.20.0"
    }
  },
  "submit": {
    "production": {}
  }
}
