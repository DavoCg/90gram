{
  "expo": {
    "name": "getvinyls",
    "slug": "getvinyls",
    "version": "0.1.0",
    "scheme": "getvinyls",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.getvinyls.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.getvinyls.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "MODIFY_AUDIO_SETTINGS",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-system-ui",
      [
        "react-native-audio-api",
        {
          "iosBackgroundMode": true,
          "androidPermissions": [
            "MODIFY_AUDIO_SETTINGS",
            "FOREGROUND_SERVICE",
            "FOREGROUND_SERVICE_MEDIA_PLAYBACK"
          ],
          "androidForegroundService": true,
          "androidFSTypes": [
            "mediaPlayback"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "00885d7a-243d-425b-aa01-6fb9912702b7"
      }
    },
    "owner": "davidrebind"
  }
}
