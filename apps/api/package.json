{
  "name": "@getvinyls/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @getvinyls/db generate && pnpm --filter @getvinyls/db migrate:deploy && tsx watch src/index.ts",
    "start": "pnpm --filter @getvinyls/db migrate:deploy && node dist/index.js",
    "build": "tsup",
    "gen:openapi": "tsx scripts/dump-openapi.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.14",
    "@getvinyls/db": "workspace:*",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.10.20",
    "better-auth": "^1.6.14",
    "dotenv": "^17.4.2",
    "hono": "^4.12.23",
    "meilisearch": "^0.58.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@getvinyls/tsconfig": "workspace:*",
    "@types/node": "^22.19.0",
    "tsup": "^8.5.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.0"
  }
}
